# Server port (default: 8080)
PORT=8080

# JWT secret key — change this to a long random string in production
JWT_SECRET=techtrack_ai_secret_key_12345

# MongoDB connection string
# Use your Atlas URI from https://cloud.mongodb.com or leave empty to use local JSON fallback
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/techtrack-ai

# Google Gemini API Key (optional — app works without it using rule engine fallback)
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
